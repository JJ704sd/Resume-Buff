# 简历帮 - 后端环境变量模板
# 复制为 .env 后填入真实 key (前端/进程不会自动读 .env,需自己 source 或在启动前 export)

# ===== LLM 智能改写 (Round 2 #3) =====
# OpenAI 兼容 HTTP 协议的 API key。留空 → LLM 改写自动关闭,resume 走原文。
LLM_API_KEY=

# OpenAI 兼容 base url,默认官方;自建网关 (e.g. Azure / OneAPI) 改成对应地址
LLM_BASE_URL=https://api.openai.com/v1

# 模型名,默认 gpt-4o-mini (性价比);想用更大的就改成 gpt-4o
LLM_MODEL=gpt-4o-mini

# 启用控制: auto (有 key 就开,没 key 就关) | true | false
# 设成 false 可以强制关闭 LLM 改写 (即使有 key)
LLM_ENABLED=auto